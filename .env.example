# Copy to .env and adjust if needed. Compose has sane local defaults, so .env is optional.
# Never commit a real .env (it is git-ignored).

# Postgres (admin / bootstrap)
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=postgres
POSTGRES_DB=orderflow

# Per-service DB users (must match infra/postgres/init.sql)
ORDER_DB_USER=order_user
ORDER_DB_PASSWORD=order_pw
INVENTORY_DB_USER=inventory_user
INVENTORY_DB_PASSWORD=inventory_pw
PAYMENT_DB_USER=payment_user
PAYMENT_DB_PASSWORD=payment_pw
SHIPMENT_DB_USER=shipment_user
SHIPMENT_DB_PASSWORD=shipment_pw

# Kafka (host processes use localhost:29092; containers use kafka:9092)
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
